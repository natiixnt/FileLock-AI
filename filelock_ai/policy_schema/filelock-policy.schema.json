{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://filelock-ai.dev/schemas/filelock-policy.schema.json",
  "title": "FileLock AI Policy",
  "description": "Schema for FileLock AI policy files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default_action", "rules"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Policy schema version."
    },
    "default_action": {
      "$ref": "#/$defs/action"
    },
    "case_sensitive": {
      "type": "boolean"
    },
    "symlink_policy": {
      "$ref": "#/$defs/actionOrAllowAlias"
    },
    "include": {
      "$ref": "#/$defs/stringOrStringArray"
    },
    "tag_packs": {
      "$ref": "#/$defs/stringOrStringArray"
    },
    "tag_definitions": {
      "$ref": "#/$defs/tagDefinitions"
    },
    "tags": {
      "$ref": "#/$defs/tagDefinitions",
      "description": "Legacy alias for tag_definitions."
    },
    "tag_severity": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/severity"
      }
    },
    "severity_gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "approval_at_or_above": {
          "$ref": "#/$defs/severity"
        },
        "block_at_or_above": {
          "$ref": "#/$defs/severity"
        }
      }
    },
    "minimum_severity_for_approval": {
      "$ref": "#/$defs/severity"
    },
    "minimum_severity_for_block": {
      "$ref": "#/$defs/severity"
    },
    "codeowners": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "tag_prefix": {
          "type": "string"
        }
      }
    },
    "rule_groups": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/ruleDefinition"
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/ruleDefinition"
          },
          {
            "$ref": "#/$defs/ruleGroupReference"
          }
        ]
      }
    }
  },
  "$defs": {
    "action": {
      "type": "string",
      "enum": ["allowed", "manual_approval", "readonly", "blocked"]
    },
    "actionOrAllowAlias": {
      "type": "string",
      "enum": ["allow", "allowed", "manual_approval", "readonly", "blocked"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stringOrStringArray": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/stringArray"
        }
      ]
    },
    "tagDefinitions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/stringOrStringArray"
      }
    },
    "ruleDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "path_glob": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "path_globs": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "paths": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "glob": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "file_extension": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "extensions": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "ext": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "directory": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "directories": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "dir": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "tags": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "tag": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "branch": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "branches": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "environment": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "environments": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "env": {
          "$ref": "#/$defs/stringOrStringArray"
        }
      }
    },
    "ruleGroupReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use_group": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "use_groups": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "name_prefix": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": ["use_group"]
        },
        {
          "required": ["use_groups"]
        }
      ]
    }
  }
}
